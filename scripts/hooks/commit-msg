#!/bin/sh
# Enforce conventional commit message format.
#
# Allowed: feat|fix|refactor|docs|test|chore|perf|ci|release(scope)?: description
# Also allowed: Merge commits and Reverts (auto-generated by git).

commit_msg_file="$1"
commit_msg=$(head -1 "$commit_msg_file")

# Allow merge commits
if echo "$commit_msg" | grep -qE "^Merge "; then
  exit 0
fi

# Allow reverts
if echo "$commit_msg" | grep -qE "^Revert "; then
  exit 0
fi

# Validate conventional commit format
if echo "$commit_msg" | grep -qE "^(feat|fix|refactor|docs|test|chore|perf|ci|release)(\([^)]+\))?: .{3,}"; then
  exit 0
fi

echo ""
echo "ERROR: Commit message does not follow conventional format."
echo ""
echo "Expected: <type>(<scope>): <description>"
echo ""
echo "Types: feat, fix, refactor, docs, test, chore, perf, ci, release"
echo ""
echo "Examples:"
echo "  feat: add ARSO radar source"
echo "  fix(dwd): handle timeout in directory listing"
echo "  chore: update dependencies"
echo "  release: v2.9.0"
echo ""
echo "Your message: $commit_msg"
echo ""
exit 1
